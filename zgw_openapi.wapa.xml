<%@page language="abap"%>                                                                                                                                                                                                                                      
<%@extension name="htmlb" prefix="htmlb"%>                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
<!DOCTYPE HTML>                                                                                                                                                                                                                                                
<html>                                                                                                                                                                                                                                                         
<head>                                                                                                                                                                                                                                                         
  <meta charset="UTF-8">                                                                                                                                                                                                                                       
  <title>Swagger UI - SAP API</title>                                                                                                                                                                                                                          
  <link rel="icon" type="image/png" href="./favicon-32x32.png" sizes="32x32" />                                                                                                                                                                                
  <link rel="icon" type="image/png" href="./favicon-16x16.png" sizes="16x16" />                                                                                                                                                                                
  <link rel="stylesheet" type="text/css" href="swagger-ui.css" >                                                                                                                                                                                               
  <style>                                                                                                                                                                                                                                                      
    html {                                                                                                                                                                                                                                                     
      box-sizing: border-box;                                                                                                                                                                                                                                  
      overflow-y: scroll;                                                                                                                                                                                                                                      
    }                                                                                                                                                                                                                                                          
    *, *:before, *:after {                                                                                                                                                                                                                                     
      box-sizing: inherit;                                                                                                                                                                                                                                     
    }                                                                                                                                                                                                                                                          
    body {                                                                                                                                                                                                                                                     
      margin: 0;                                                                                                                                                                                                                                               
      background: #fafafa;                                                                                                                                                                                                                                     
    }                                                                                                                                                                                                                                                          
    .url {                                                                                                                                                                                                                                                     
      visibility: hidden;                                                                                                                                                                                                                                      
    }                                                                                                                                                                                                                                                          
  </style>                                                                                                                                                                                                                                                     
</head>                                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
<body>                                                                                                                                                                                                                                                         
    <div id="swagger-ui"></div>                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
    <script src="swagger-ui-bundle.js"></script>                                                                                                                                                                                                               
    <script src="swagger-ui-standalone-preset.js"></script>                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
    <script>                                                                                                                                                                                                                                                   
        window.onload = function() {                                                                                                                                                                                                                           
          const ui = SwaggerUIBundle({                                                                                                                                                                                                                         
            url: "<%= json_url %>",                                                                                                                                                                                                                            
            dom_id: '#swagger-ui',                                                                                                                                                                                                                             
            deepLinking: true,                                                                                                                                                                                                                                 
            presets: [                                                                                                                                                                                                                                         
              SwaggerUIBundle.presets.apis,                                                                                                                                                                                                                    
              SwaggerUIStandalonePreset                                                                                                                                                                                                                        
            ],                                                                                                                                                                                                                                                 
            plugins: [                                                                                                                                                                                                                                         
              SwaggerUIBundle.plugins.DownloadUrl                                                                                                                                                                                                              
            ],                                                                                                                                                                                                                                                 
            layout: "BaseLayout",                                                                                                                                                                                                                              
            requestInterceptor: function(req) {                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
              // 1. Overslaan bij laden van de specificatie of GET requests (geen CSRF/ETag nodig)                                                                                                                                                             
              if( req.loadSpec === true || req.method === "GET" ){                                                                                                                                                                                             
                return req;                                                                                                                                                                                                                                    
              }                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
              // 2. ETag ophalen voor wijzigingsverzoeken (PATCH, PUT, DELETE)                                                                                                                                                                                 
              if( ["PATCH", "PUT", "DELETE"].includes(req.method) ){                                                                                                                                                                                           
                var etagRequest = new XMLHttpRequest();                                                                                                                                                                                                        
                etagRequest.open('GET', req.url, false); // Synchroon om de flow niet te breken                                                                                                                                                                
                etagRequest.send(null);                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
                if (etagRequest.status === 200) {                                                                                                                                                                                                              
                  var etag = etagRequest.getResponseHeader('etag');                                                                                                                                                                                            
                  if( etag ){                                                                                                                                                                                                                                  
                    req.headers['If-Match'] = etag;                                                                                                                                                                                                            
                  }                                                                                                                                                                                                                                            
                }                                                                                                                                                                                                                                              
              }                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
              // 3. CSRF-token ophalen van de geselecteerde server                                                                                                                                                                                             
              var server = "";                                                                                                                                                                                                                                 
              var serverDropDown = document.querySelector('.servers select');                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
              if (serverDropDown) {                                                                                                                                                                                                                            
                server = serverDropDown.value;                                                                                                                                                                                                                 
              } else {                                                                                                                                                                                                                                         
                // Fallback naar de basis URL als de dropdown (nog) niet bestaat                                                                                                                                                                               
                server = window.location.origin;                                                                                                                                                                                                               
              }                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
              var csrfRequest = new XMLHttpRequest();                                                                                                                                                                                                          
              csrfRequest.open('GET', server, false);                                                                                                                                                                                                          
              csrfRequest.setRequestHeader("X-CSRF-Token", "Fetch");                                                                                                                                                                                           
              csrfRequest.send(null);                                                                                                                                                                                                                          
                                                                                                                                                                                                                                                               
              if (csrfRequest.status === 200 || csrfRequest.status === 501) {                                                                                                                                                                                  
                var csrf = csrfRequest.getResponseHeader('X-CSRF-Token');                                                                                                                                                                                      
                if (csrf) {                                                                                                                                                                                                                                    
                  req.headers['X-CSRF-TOKEN'] = csrf;                                                                                                                                                                                                          
                }                                                                                                                                                                                                                                              
              }                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
              return req;                                                                                                                                                                                                                                      
            },                                                                                                                                                                                                                                                 
          });                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
          window.ui = ui;                                                                                                                                                                                                                                      
        }                                                                                                                                                                                                                                                      
    </script>                                                                                                                                                                                                                                                  
</body>                                                                                                                                                                                                                                                        
</html>                                                                                                                                                                                                                                                        